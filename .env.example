# Local Ollama on your LAN (vision model required)
OLLAMA_BASE_URL=http://192.168.1.25:11434
# Must be a vision-capable model on your Ollama host (ollama list)
OLLAMA_MODEL=gemma4:latest
OLLAMA_TIMEOUT=120

# Optional: OpenAI vision (if you have a key)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# Expose on home LAN (iPhone, other PCs) — use scripts/dev-lan.sh
LAN_EXPOSE=true
# Frontend dev server port (default 5173)
# PORT=5173
# Your Mac's LAN IP (find with: ipconfig getifaddr en0)
CORS_ORIGINS=http://localhost:5173,http://192.168.1.89:5173

# Notion two-way sync (see README)
NOTION_TOKEN=secret_your_integration_token
NOTION_PARENT_PAGE_ID=your_notion_page_id
# Set after first bootstrap (logged on startup), or leave empty to auto-create
# NOTION_DATABASE_ID=e64af6b4-fb5f-4832-b9b2-7c22493a5eda
NOTION_SYNC_ENABLED=true
NOTION_SYNC_POLL_SECONDS=300

# Google Drive photo backup (see README — personal Gmail uses OAuth)
GOOGLE_DRIVE_FOLDER_NAME=namecard
# GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_OAUTH_CLIENT_PATH=backend/google-oauth-client.json
# Service account (Workspace Shared drives only):
# GOOGLE_DRIVE_CREDENTIALS_PATH=backend/google-drive-credentials.json
